{
  "name": "kanden-subsidy-demo",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,server -c \"blue,green\" \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "vite",
    "dev:server": "npm --prefix server run dev",
    "build": "tsc -b && vite build && npm --prefix server run build",
    "preview": "vite preview",
    "lint": "tsc --noEmit && npm --prefix server run build -- --noEmit",
    "postinstall": "npm --prefix server install"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
