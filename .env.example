# ===== Vite フロント側（公開可情報のみ） =====
# 機密情報は絶対にここに置かない
# 実APIを叩く（モック無効）にするため false
VITE_USE_MOCK=false
# 空にすると相対URL（/api/*）で叩く → Vite プロキシ経由で Express(:3001) に届く
# 同一オリジン化することでベーシック認証が1度で両方に効く
VITE_API_BASE_URL=

# ベーシック認証（dev サーバへのアクセス制限）。空欄なら test/test
BASIC_AUTH_USER=test
BASIC_AUTH_PASS=test

# ===== サーバ側環境変数は server/.env.example を参照 =====
