# ===== サーバ側環境変数 =====
# このファイルは雛形。実値は server/.env （gitignore済み）に書く。

# --- マイナポータルAPI（検証環境） ---
MYNA_API_BASE=https://app-st-local.oss.myna.go.jp
MYNA_PROVIDER_ID=30ca38a5-1184-4ddc-80f3-fb9de7e0d32c
MYNA_PROVIDER_PASSWORD=NbS$RDRi_Y2iG%TiX-GB

# --- OpenAI API ---
OPENAI_API_KEY=sk-...your_key_here...
# 設計プラン記載のモデル。コスト/速度に応じて変更可（例: gpt-4o-mini, gpt-4o）
OPENAI_MODEL=gpt-5.4-mini

# --- サーバ設定 ---
PORT=3001
# Vite dev server からのCORSを許可するオリジン（カンマ区切りで複数可）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- マッチング動作チューニング ---
# 一覧検索で取得する最大件数（マイナポータル側上限は500）
MYNA_LIST_LIMIT=30
# 詳細検索＋LLM判定する上位件数（マッチング対象、安全網としての上限）
# 通常のヒット数（10-30件程度）なら全件カバーできる。500件など過剰時の負荷防止
MATCH_DETAIL_TOP_N=50

# --- ベーシック認証（dev / preview 用、空欄なら test/test）---
BASIC_AUTH_USER=test
BASIC_AUTH_PASS=test
